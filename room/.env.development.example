# Copy to .env.development and fill in. The real file is gitignored.

PORT=3002
CORS_ORIGIN=*

# Cloudflare TURN credentials (Realtime > TURN in dashboard).
# Leave blank to disable TURN — calls will then only work between peers
# on the same LAN / behind permissive NATs. Both values are server-only;
# they never reach the browser.
CLOUDFLARE_TURN_TOKEN_ID=
CLOUDFLARE_TURN_API_TOKEN=

# Gemini API key (Google AI Studio) for chat translation. Used by
# /translate endpoint. Without it, /translate returns 503 and the chat
# UI silently falls back to showing only the original text.
GEMINI_API_KEY=
# Optional override — defaults to gemini-2.5-flash. Other valid values:
# gemini-2.5-flash-lite (cheaper), gemini-2.5-pro (slower/better).
GEMINI_TRANSLATION_MODEL=gemini-2.5-flash

# Deepgram — realtime speech-to-text via WebSocket. Server opens a
# parallel WS to Deepgram per user, pipes 16kHz PCM frames in, pipes
# transcripts back. Used by the /stt WebSocket endpoint. Without it,
# /stt rejects with 503 and the meeting UI silently disables live
# subtitles. Nova-3 supports Vietnamese (`vi`) and Korean (`ko`).
DEEPGRAM_API_KEY=
# Optional override — defaults to nova-3 (latest, lowest WER).
DEEPGRAM_STT_MODEL=nova-3
